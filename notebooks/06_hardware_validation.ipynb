         color='#1f78b4', linestyle='--', marker='o', linewidth=2)
plt.errorbar(df_gap['Depth'], df_gap['Physical_QPU'], yerr=qpu_error, label=f'Physical Hardware ({hardware_metadata["Target_Backend"]})', 
             color='#e31a1c', fmt='-s', linewidth=2.5, capsize=5)

# Fill Area to Explicitly Highlight the Reality Gap (4% to 8%)
plt.fill_between(df_gap['Depth'], df_gap['Ideal_Simulation'], df_gap['Physical_QPU'], 
                 color='#mediumpurple', alpha=0.15, label='Quantified Reality Gap (4%–8% Variance)')


# %% [markdown]
# ## 2. Circuit Assembly with Embedded QED Architecture
# We construct a verified 4-qubit cluster state wrapped inside localized QED ancilla syndrome checks.

# %%
def build_hardware_circuit_with_qed():
    # 4 Data Qubits, 1 Ancilla Syndrome Flag Qubit
    qr = QuantumRegister(4, name="data")
    anc = QuantumRegister(1, name="qed_ancilla")
    cr = ClassicalRegister(4, name="meas")
    syn_cr = ClassicalRegister(1, name="syndrome")
    
    qc = QuantumCircuit(qr, anc, cr, syn_cr)
    
    # 1. State Preparation (Cluster State)
    qc.h(qr[0])
    qc.h(qr[1])
    qc.cx(qr[0], qr[2])
    qc.cx(qr[1], qr[3])
    
    # 2. Synchronous Low-Latency QED Verification Block
    # Entangle data parity to check for single-qubit phase/bit flips
    qc.cx(qr[0], anc[0])
    qc.cx(qr[2], anc[0])
    
    # Measure Syndrome to Classical Bit
    qc.measure(anc[0], syn_cr[0])
    
    # Reset ancilla loop immediately for low-overhead re-use
    qc.reset(anc[0])
    
    # 3. Final Physical Readout Measurement Matrix
    qc.measure(qr, cr)
    return qc

hardware_qc = build_hardware_circuit_with_qed()
print("\nGenerated Hardware Verification Quantum Defect Topography:")
print(hardware_qc.draw(output='text'))

# %% [markdown]
# ## 3. Physical Execution Post-Selection System Engine
# This logic processes physical output bitstrings and implements the clean 
# algorithmic post-selection filter, discarding data where the syndrome bit registers an error.

# %%
def process_hardware_post_selection(raw_counts, shots):
    """
    Parses hardware output bitstrings.
    Format assumes: 'data_string syndrome_bit' (e.g., '1010 0' means no error detected).
    """
    accepted_shots = 0
    filtered_counts = {}
    
    for bitstring, count in raw_counts.items():
        # Split data bits from syndrome flag
        parts = bitstring.split()
        if len(parts) == 2:
            data_bits, syndrome = parts[0], parts[1]
        else:
            # Handle non-spaced default string layout variations
            data_bits, syndrome = bitstring[:-1], bitstring[-1]
            
        if syndrome == '0':  # Error Flag clear
            filtered_counts[data_bits] = filtered_counts.get(data_bits, 0) + count
            accepted_shots += count
            
    retention_fraction = accepted_shots / shots
    return filtered_counts, retention_fraction

# Simulate QPU counts containing physical noise profiles
simulated_raw_qpu_counts = {
    '0000 0': 1850, '1010 0': 2100, '0101 0': 1950, '1111 0': 1200, # Valid states
    '0001 1': 320,  '0100 1': 280,  '1000 1': 292,  '1110 1': 200   # Error states caught
}

filtered, retention = process_hardware_post_selection(simulated_raw_qpu_counts, hardware_metadata["Configured_Shots"])
print(f"Post-Selection Event Filter Processing Completed.")
print(f"Verified State Retention Fraction: {retention:.4f} ({retention*100:.2f}%)")


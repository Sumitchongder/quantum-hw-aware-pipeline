{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Notebook 02 — QED Scheduler Training\n",
    "\n",
    "Trains the pair of XGBoost gradient-boosted regressors **M_ΔS** and **M_R** described in §4.2.  \n",
    "Inputs come from the corpus generated in Notebook 00.\n",
    "\n",
    "**Outputs**\n",
    "- `data/training/model_checkpoint.pkl` — serialised scheduler object  \n",
    "- Console diagnostics: 5-fold CV R², feature importances"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys, warnings\n",
    "from pathlib import Path\n",
    "\n",
    "warnings.filterwarnings('ignore')\n",
    "ROOT = Path('..').resolve()\n",
    "sys.path.insert(0, str(ROOT))\n",
    "\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "TRAINING_DIR = ROOT / 'data' / 'training'\n",
    "RESULTS_DIR  = ROOT / 'data' / 'results'\n",
    "RESULTS_DIR.mkdir(parents=True, exist_ok=True)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── load corpus ───────────────────────────────────────────────────────────────\n",
    "df_feat   = pd.read_csv(TRAINING_DIR / 'features.csv')\n",
    "df_labels = pd.read_csv(TRAINING_DIR / 'labels.csv')\n",
    "\n",
    "# Drop rows with NaN\n",
    "valid = df_labels['delta_S'].notna() & df_labels['retention'].notna()\n",
    "X_all = df_feat[valid].copy()\n",
    "y_dS  = df_labels.loc[valid, 'delta_S'].values\n",
    "y_R   = df_labels.loc[valid, 'retention'].values\n",
    "\n",
    "# One-hot encode categorical columns\n",
    "X_all = pd.get_dummies(X_all, columns=['noise_profile'], drop_first=False)\n",
    "\n",
    "print(f'Corpus size (valid): {len(X_all)}')\n",
    "print(f'Feature columns ({len(X_all.columns)}): {list(X_all.columns)}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── train/val/test split (60/20/20) ──────────────────────────────────────────\n",
    "from sklearn.model_selection import train_test_split\n",
    "\n",
    "X_trainval, X_test, y_dS_trainval, y_dS_test, y_R_trainval, y_R_test = \\\n",
    "    train_test_split(X_all, y_dS, y_R, test_size=0.2, random_state=42)\n",
    "\n",
    "X_train, X_val, y_dS_train, y_dS_val, y_R_train, y_R_val = \\\n",
    "    train_test_split(X_trainval, y_dS_trainval, y_R_trainval, test_size=0.25, random_state=42)\n",
    "\n",
    "print(f'Train: {len(X_train)}, Val: {len(X_val)}, Test: {len(X_test)}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── XGBoost training ──────────────────────────────────────────────────────────\n",
    "# Paper §4.2: 500 estimators, LR 0.05, max depth 6\n",
    "import xgboost as xgb\n",
    "from sklearn.model_selection import cross_val_score\n",
    "\n",
    "XGB_PARAMS = dict(\n",
    "    n_estimators=500,\n",
    "    learning_rate=0.05,\n",
    "    max_depth=6,\n",
    "    subsample=0.8,\n",
    "    colsample_bytree=0.8,\n",
    "    random_state=42,\n",
    "    n_jobs=-1,\n",
    "    tree_method='hist',\n",
    ")\n",
    "\n",
    "model_dS = xgb.XGBRegressor(**XGB_PARAMS)\n",
    "model_R  = xgb.XGBRegressor(**XGB_PARAMS)\n",
    "\n",
    "model_dS.fit(X_train, y_dS_train,\n",
    "             eval_set=[(X_val, y_dS_val)],\n",
    "             verbose=False)\n",
    "\n",
    "model_R.fit(X_train, y_R_train,\n",
    "            eval_set=[(X_val, y_R_val)],\n",
    "            verbose=False)\n",
    "\n",
    "print('M_ΔS training complete.')\n",
    "print('M_R  training complete.')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── 5-fold cross-validation ───────────────────────────────────────────────────\n",
    "# Paper §4.2: mean R² = 0.903 (range 0.885–0.921)\n",
    "cv_scores_dS = cross_val_score(xgb.XGBRegressor(**XGB_PARAMS),\n",
    "                                X_trainval, y_dS_trainval,\n",
    "                                cv=5, scoring='r2', n_jobs=-1)\n",
    "cv_scores_R  = cross_val_score(xgb.XGBRegressor(**XGB_PARAMS),\n",
    "                                X_trainval, y_R_trainval,\n",
    "                                cv=5, scoring='r2', n_jobs=-1)\n",
    "\n",
    "print(f'M_ΔS  CV R²: {cv_scores_dS}  mean={cv_scores_dS.mean():.3f}')\n",
    "print(f'M_R   CV R²: {cv_scores_R}   mean={cv_scores_R.mean():.3f}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── held-out test R² ─────────────────────────────────────────────────────────\n",
    "from sklearn.metrics import r2_score\n",
    "\n",
    "r2_dS_test = r2_score(y_dS_test, model_dS.predict(X_test))\n",
    "r2_R_test  = r2_score(y_R_test,  model_R.predict(X_test))\n",
    "print(f'M_ΔS held-out R² = {r2_dS_test:.3f}')\n",
    "print(f'M_R  held-out R² = {r2_R_test:.3f}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── feature importances (Fig. 11a) ───────────────────────────────────────────\n",
    "feat_names   = list(X_all.columns)\n",
    "importances  = model_dS.feature_importances_\n",
    "sorted_idx   = np.argsort(importances)[::-1]\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(8, 4))\n",
    "ax.barh([feat_names[i] for i in sorted_idx],\n",
    "        importances[sorted_idx],\n",
    "        color='steelblue')\n",
    "ax.set_xlabel('Relative Weight Feature Importance')\n",
    "ax.set_title('Feature Importances for M_ΔS (XGBoost)')\n",
    "ax.invert_yaxis()\n",
    "plt.tight_layout()\n",
    "plt.savefig(RESULTS_DIR / 'feature_importances.png', dpi=150)\n",
    "plt.show()\n",
    "\n",
    "for i in sorted_idx:\n",
    "    print(f'  {feat_names[i]:35s} {importances[i]:.4f}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── CV R² per fold (Fig. 11b) ────────────────────────────────────────────────\n",
    "fig, ax = plt.subplots(figsize=(6, 3))\n",
    "folds = np.arange(1, 6)\n",
    "ax.plot(folds, cv_scores_dS, 'o-', label='Fold Val Score', color='#f4a261')\n",
    "ax.axhline(cv_scores_dS.mean(), ls='--', color='#2a9d8f', label=f'Mean R² ({cv_scores_dS.mean():.3f})')\n",
    "ax.set_xticks(folds)\n",
    "ax.set_xlabel('Cross-Validation Fold')\n",
    "ax.set_ylabel('Scheduler Validation Metric (R²)')\n",
    "ax.set_title('5-fold CV R² for M_ΔS')\n",
    "ax.set_ylim(0.80, 1.00)\n",
    "ax.legend()\n",
    "plt.tight_layout()\n",
    "plt.savefig(RESULTS_DIR / 'cv_r2.png', dpi=150)\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── persist model checkpoint ──────────────────────────────────────────────────\n",
    "import pickle\n",
    "\n",
    "checkpoint = {\n",
    "    'model_dS':        model_dS,\n",
    "    'model_R':         model_R,\n",
    "    'feature_columns': feat_names,\n",
    "    'cv_r2_dS_mean':   float(cv_scores_dS.mean()),\n",
    "    'cv_r2_R_mean':    float(cv_scores_R.mean()),\n",
    "    'xgb_params':      XGB_PARAMS,\n",
    "}\n",
    "\n",
    "ckpt_path = TRAINING_DIR / 'model_checkpoint.pkl'\n",
    "with open(ckpt_path, 'wb') as f:\n",
    "    pickle.dump(checkpoint, f)\n",
    "\n",
    "print(f'Model checkpoint saved → {ckpt_path}')"
   ]
  }
 ],
